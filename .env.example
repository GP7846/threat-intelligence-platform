# ── Copy this file to .env and fill in your real values ──────
# Never commit .env to version control!

# ── MongoDB ───────────────────────────────────────────────────
MONGO_URI=mongodb://localhost:27017/
DB_NAME=threat_intel

# ── Enforcer ──────────────────────────────────────────────────
# Minimum risk score (0-100) to trigger an auto-block
BLOCK_THRESHOLD=70

# ── OSINT Feed API Keys ───────────────────────────────────────
ALIENVAULT_API_KEY="API_KEY"
VIRUSTOTAL_API_KEY="API_KEY"
ABUSEIPDB_API_KEY="API_KEY"

# ── Alerting (optional) ───────────────────────────────────────
DISCORD_WEBHOOK_URL="https://discord.com/api/webhooks/YOUR/WEBHOOK"
SLACK_WEBHOOK_URL="https://hooks.slack.com/services/YOUR/SLACK/WEBHOOK"

# ── Elasticsearch / ELK (optional) ───────────────────────────
ELASTICSEARCH_URL="http://localhost:9200"
ES_INDEX_NAME="threat-intelligence"

# ── Dashboard ─────────────────────────────────────────────────
DASHBOARD_HOST=0.0.0.0
DASHBOARD_PORT=5000
